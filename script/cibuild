#!/bin/sh

set -e

script/build

if test -e "./_site/index.html";then
  echo "It builds!"
  rm -Rf _site
else
  echo "Huh. That's odd. The example site doesn't seem to build."
  exit 1
fi

# NOTE:
# This repository is a personal website, not the upstream Minima theme gem.
# The original Minima template's CI script tries to build `minima.gemspec`,
# which does not exist here and causes CI to fail after a successful site build.
echo "CI check complete."
